# 必填：百炼 API Key（与所选地域一致）
DASHSCOPE_API_KEY=

# 可选：北京默认；新加坡用 https://dashscope-intl.aliyuncs.com
# DASHSCOPE_BASE=https://dashscope.aliyuncs.com

# 可选：默认 wanx2.1-vace-plus（需与控制台开通的模型一致）
# WANX_MODEL=wanx2.1-vace-plus

# 切片时长（秒），默认 8。传 mask 走局部编辑时，单段会自动限制为 ≤5（与万相 video_edit 一致）。
# VIDEO_CHUNK_SECONDS=8

# video_repainting 时控制与原片构图/动作贴合程度，默认 1.0（越大越贴近原视频，越小越自由）
# WANX_STRENGTH=1

# 传 mask 时：角标位置固定用 fixed；会跟物体动才用 tracking
# WANX_MASK_TYPE=fixed

# 客户端也可不传 mask 文件，仅传表单 mask_preset=tl|tr|bl|br，由服务端用 ffmpeg 按角生成矩形白区（见 src/services/logo-mask.ts）

# 万相轮询（毫秒）
# WANX_POLL_INTERVAL_MS=15000
# WANX_POLL_MAX_MS=900000

# Logo 仅替换场景建议：不要开启扩写；参考图作「主体」用 obj（默认即可，勿设 bg）
# WANX_PROMPT_EXTEND=false
# WANX_OBJ_OR_BG=obj
# 局部编辑 video_edit 单张参考图时默认 obj；仅当参考图作「背景」时用 true
# WANX_VIDEO_EDIT_REF_BG=false
# 控制条件：人物镜头可用 posebodyface；无人物/产品镜头可尝试 depth 等（见万相文档）
# WANX_CONTROL_CONDITION=posebodyface

# 服务端口
# PORT=3000
